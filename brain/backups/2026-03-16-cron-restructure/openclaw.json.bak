        "anthropic/claude-sonnet-4-5": {
          "alias": "sonnet"
        },
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet46"
        }
      },
      "workspace": "/home/rob/.openclaw/workspace",
      "maxConcurrent": 6,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
