  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "attachOnly": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "cdpUrl": "http://127.0.0.1:18800",
        "color": "#00AA00"
